# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Secret Key untuk session encryption
# Untuk production: Ganti dengan string yang lebih aman dan random
SECRET_KEY=your-super-secret-key-change-in-production

# Upload Configuration
MAX_FILE_SIZE=52428800  # 50 MB dalam bytes
UPLOAD_FOLDER=uploads

# Database (jika digunakan)
# DATABASE_URL=sqlite:///app.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Application Settings
APP_NAME=Aplikasi Koreksi Tanda Baca
APP_VERSION=1.0.0
